{
  "datasets": [
    {
      "name": "kpis",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT COUNT(*) AS total_claims, SUM(CASE WHEN claim_status='denied' THEN 1 ELSE 0 END) AS denied_claims, ROUND(SUM(CASE WHEN claim_status='denied' THEN 1 ELSE 0 END)/COUNT(*),4) AS denial_rate FROM northwind.contract_intelligence.claims"
      ]
    },
    {
      "name": "underpayment",
      "displayName": "Underpayment by payer",
      "queryLines": [
        "SELECT payer_name, ROUND(SUM(underpayment_dollars),2) AS underpayment FROM northwind.contract_intelligence.underpayment_dollars_by_payer_drg GROUP BY payer_name ORDER BY underpayment DESC"
      ]
    },
    {
      "name": "denial",
      "displayName": "Denial rate by payer",
      "queryLines": [
        "SELECT payer_name, ROUND(SUM(denied_claims)/SUM(total_claims),4) AS denial_rate FROM northwind.contract_intelligence.denial_rate_by_payer GROUP BY payer_name ORDER BY denial_rate DESC"
      ]
    },
    {
      "name": "variance",
      "displayName": "Variance by quarter",
      "queryLines": [
        "SELECT service_quarter, ROUND(SUM(variance_amount),2) AS variance_amount FROM northwind.contract_intelligence.reimbursement_variance GROUP BY service_quarter ORDER BY service_quarter"
      ]
    },
    {
      "name": "renewal",
      "displayName": "Renewal risk",
      "queryLines": [
        "SELECT payer_name, term_date, days_to_renewal, renewal_window, total_underpayment, denial_rate FROM northwind.contract_intelligence.renewal_risk ORDER BY days_to_renewal"
      ]
    },
    {
      "name": "topdrg",
      "displayName": "Top DRG leaks",
      "queryLines": [
        "SELECT payer_name, drg_code, drg_description, ROUND(SUM(underpayment_dollars),2) AS underpayment FROM northwind.contract_intelligence.underpayment_dollars_by_payer_drg GROUP BY payer_name, drg_code, drg_description ORDER BY underpayment DESC LIMIT 10"
      ]
    }
  ],
